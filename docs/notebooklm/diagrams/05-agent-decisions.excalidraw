    {
      "id": "brief_text",
      "type": "text",
      "x": 440,
      "y": 280,
      "width": 370,
      "height": 84,
      "text": "WHY \u2014 geopolitical or economic driver\n        (state actor intent, structural instability)\n\nHOW \u2014 which assets are exposed and how\n        (without technical attack mechanics)\n\nSO WHAT \u2014 business impact in dollars\n        (VaCR figure + effect on operations)",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "strokeColor": "#1e1e2e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
