    {
      "id": "gk_rule_text",
      "type": "text",
      "x": 30,
      "y": 280,
      "width": 370,
      "height": 84,
      "text": "ESCALATE if scenario is top-4 by financial impact:\n#1 Ransomware (37.6%)  \u2192  ESCALATE\n#2 Accidental Disclosure (36.1%)  \u2192  ESCALATE\n#3 System Intrusion (21.4%)  \u2192  ESCALATE\n#4 Insider Misuse (4.4%)  \u2192  ESCALATE\n#5+ \u2192  MONITOR or CLEAR",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "strokeColor": "#1e1e2e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5852597,
      "version": 1,
      "versionNonce": 1679537,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1700000000000,
      "link": null,
      "locked": false,
      "groupIds": [],
      "strokeStyle": "solid",
      "containerId": null,
      "lineHeight": 1.25,
      "originalText": "ESCALATE if scenario is top-4 by financial impact:\n#1 Ransomware (37.6%)  \u2192  ESCALATE\n#2 Accidental Disclosure (36.1%)  \u2192  ESCALATE\n#3 System Intrusion (21.4%)  \u2192  ESCALATE\n#4 Insider Misuse (4.4%)  \u2192  ESCALATE\n#5+ \u2192  MONITOR or CLEAR",
      "autoResize": true
    },
