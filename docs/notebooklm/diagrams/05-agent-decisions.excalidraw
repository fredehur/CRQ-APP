    {
      "id": "circuit_text",
      "type": "text",
      "x": 440,
      "y": 428,
      "width": 370,
      "height": 94,
      "text": "Each quality gate has a retry counter.\n\nAttempt 1 \u2192 fail \u2192 agent rewrites\nAttempt 2 \u2192 fail \u2192 agent rewrites\nAttempt 3 \u2192 fail \u2192 FORCE APPROVE\n             + escalate to human operator\n\nPipeline never hangs indefinitely.",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "strokeColor": "#1e1e2e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
