    {
      "id": "adm_text",
      "type": "text",
      "x": 30,
      "y": 428,
      "width": 370,
      "height": 94,
      "text": "Source reliability (letter):\nA=Completely reliable  B=Usually reliable  C=Fairly reliable\nD=Not usually reliable  E=Unreliable  F=Cannot be judged\n\nInformation credibility (number):\n1=Confirmed  2=Probably true  3=Possibly true\n4=Doubtful  5=Improbable  6=Cannot be judged\n\nAll 3 escalated regions this run: B2",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "middle",
      "strokeColor": "#1e1e2e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 5315886,
