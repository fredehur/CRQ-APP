# CRQ Pipeline — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# --- OSINT Mode ---
# Set to true to use live OSINT backends (Tavily/DDG/Seerist).
# Default (false/unset): mock fixtures — deterministic, no API calls, safe for dev/testing.
# Flip to true for real board-facing pipeline runs.
OSINT_LIVE=false

# --- Live OSINT: Web Search ---
# Tavily Search API (optional — higher quality than DDG, paid)
# Sign up: https://tavily.com
TAVILY_API_KEY=

# --- Live OSINT: Seerist Geopolitical Intelligence ---
# Seerist REST API (requires commercial contract — contact sales@seerist.com)
# Formerly Geospark Analytics. Strategic partner: Control Risks.
# Provides: PulseAI stability scores, EventsAI event feed, HotspotsAI anomalies,
#           ScribeAI auto-assessments, Verified Events DB (2008–present)
SEERIST_API_KEY=

# Base URL — confirm with Seerist (default set in seerist_client.py)
# SEERIST_BASE_URL=https://api.seerist.com/v1

# Enable +Cyber add-on (separate license — country cyber ratings + threat actor profiles)
# SEERIST_CYBER_ADDON=true
