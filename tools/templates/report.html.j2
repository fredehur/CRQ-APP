<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Cyber Risk Intelligence Brief</title>
<style>
  :root {
    --navy:  #1e3a5f;
    --red:   #dc2626;
    --amber: #d97706;
    --green: #16a34a;
    --grey:  #6b7280;
    --divider: #f0f0f0;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: system-ui, -apple-system, "Segoe UI", sans-serif;
    font-size: 10px;
    color: #333;
    background: #fff;
    line-height: 1.6;
  }

  @page { size: A4; margin: 0; }

  @media print {
    * { print-color-adjust: exact; -webkit-print-color-adjust: exact; }
  }

  /* ── Page shell ───────────────────────────────────────────────────── */
  .page {
    page-break-before: always;
    width: 210mm;
    min-height: 297mm;
    position: relative;
    padding: 0 0 16mm 0;
    background: #fff;
  }
  .page:first-child { page-break-before: avoid; }

  /* 3px navy stripe top of every page */
  .page::before {
    content: "";
    display: block;
    height: 3px;
    background: var(--navy);
    width: 100%;
  }

  /* Inner content wrapper — uniform horizontal padding */
  .page-body {
    padding: 10mm 16mm 0;
  }

  /* ── Typography ────────────────────────────────────────────────────── */
  h1 { font-size: 22px; font-weight: 700; color: #111; line-height: 1.25; }
  h2 { font-size: 16px; font-weight: 700; color: #111; line-height: 1.3; }
  h3 { font-size: 12px; font-weight: 700; color: #111; }

  .label {
    font-size: 8px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--navy);
  }

  .meta-text {
    font-size: 9px;
    color: var(--grey);
  }

  /* ── Chips ─────────────────────────────────────────────────────────── */
  .chip {
    display: inline-block;
    padding: 2px 7px;
    border-radius: 3px;
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 0.5px;
    line-height: 1.6;
  }
  .chip-esc   { background: #dc2626; color: #fff; }
  .chip-mon   { background: #d97706; color: #fff; }
  .chip-clr   { background: #16a34a; color: #fff; }
  .chip-sev-critical { background: #dc2626; color: #fff; }
  .chip-sev-high     { background: #ea580c; color: #fff; }
  .chip-sev-medium   { background: #d97706; color: #fff; }
  .chip-sev-low      { background: #16a34a; color: #fff; }

  /* Inline status strip — three chips in a row */
  .status-strip {
    display: flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
  }
  .status-strip .item {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 9px;
    font-weight: 600;
  }

  /* ── Divider ───────────────────────────────────────────────────────── */
  .divider {
    border: none;
    border-top: 1px solid var(--divider);
    margin: 8px 0;
  }

  /* ══════════════════════════════════════════════════════════════════ */
  /* COVER PAGE                                                         */
  /* ══════════════════════════════════════════════════════════════════ */
  .cover-body {
    padding: 20mm 16mm 0;
    display: flex;
    flex-direction: column;
    gap: 12mm;
  }

  .cover-client {
    font-size: 10px;
    font-weight: 600;
    font-variant: small-caps;
    letter-spacing: 2px;
    color: var(--navy);
  }

  .cover-title { margin-top: 4mm; }

  .cover-subtitle {
    font-size: 14px;
    color: var(--grey);
    margin-top: 4px;
  }

  .cover-meta-block {
    margin-top: 10mm;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .cover-classification {
    display: inline-block;
    font-size: 9px;
    font-weight: 700;
    color: #dc2626;
    border: 1px solid #dc2626;
    padding: 2px 8px;
    border-radius: 2px;
    letter-spacing: 1px;
    margin-top: 2mm;
  }

  /* ══════════════════════════════════════════════════════════════════ */
  /* GLOBAL POSTURE PAGE                                               */
  /* ══════════════════════════════════════════════════════════════════ */
  .page-heading {
    margin-bottom: 6mm;
    border-bottom: 1px solid var(--divider);
    padding-bottom: 4mm;
  }
  .page-heading h2 { margin-bottom: 4px; }

  .exec-summary {
    font-size: 10px;
    line-height: 1.7;
    color: #333;
    margin: 6mm 0;
  }

  /* Region summary table */
  .region-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 9px;
    margin-top: 4mm;
  }
  .region-table th {
    background: #f8f8f8;
    color: var(--navy);
    font-size: 8px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    padding: 5px 8px;
    text-align: left;
    border-bottom: 2px solid var(--divider);
  }
  .region-table td {
    padding: 5px 8px;
    border-bottom: 1px solid var(--divider);
    vertical-align: middle;
  }
  .region-table tr:last-child td { border-bottom: none; }

  .vel-up   { color: #dc2626; font-weight: 600; }
  .vel-down { color: #16a34a; font-weight: 600; }
  .vel-flat { color: var(--grey); font-weight: 600; }
  .vel-none { color: var(--grey); }

  /* ══════════════════════════════════════════════════════════════════ */
  /* ESCALATED REGION PAGES                                            */
  /* ══════════════════════════════════════════════════════════════════ */
  .region-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 3mm;
  }

  .region-header-left h2 {
    font-size: 20px;
    font-weight: 700;
    color: #111;
  }

  .region-sub {
    font-size: 9px;
    color: var(--grey);
    margin-top: 3px;
  }

  /* ── Region meta row ──────────────────────────────────────────────── */
  .region-meta {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    font-size: 9px;
    color: var(--grey);
    margin-bottom: 4mm;
  }
  .region-meta .meta-item strong { color: #333; }

  /* ── Intelligence sections ────────────────────────────────────────── */
  .intel-section {
    margin-bottom: 4mm;
    padding-left: 3mm;
    border-left: 2px solid var(--navy);
  }
  .intel-section.impact  { border-left-color: var(--red); }
  .intel-section.watch   { border-left-color: var(--amber); }
  .intel-section.actions { border-left-color: #6b7280; }

  .section-heading {
    font-size: 8px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--navy);
    margin-bottom: 3px;
  }
  .intel-section.impact  .section-heading { color: var(--red); }
  .intel-section.watch   .section-heading { color: var(--amber); }
  .intel-section.actions .section-heading { color: #6b7280; }

  .intel-list {
    margin: 0;
    padding-left: 12px;
    font-size: 10px;
    line-height: 1.6;
    color: #333;
  }
  .intel-list li { margin-bottom: 2px; }

  /* Unavailable notice */
  .unavailable-notice {
    background: #fef3c7;
    border: 1px solid #fcd34d;
    border-radius: 4px;
    padding: 8mm;
    font-size: 9px;
    color: #92400e;
    margin-top: 5mm;
  }

  /* Region page footer */
  .region-footer {
    position: absolute;
    bottom: 6mm;
    left: 16mm;
    right: 16mm;
    border-top: 1px solid var(--divider);
    padding-top: 4px;
    font-size: 8px;
    color: var(--grey);
    display: flex;
    gap: 12px;
  }

  /* ══════════════════════════════════════════════════════════════════ */
  /* APPENDIX PAGE                                                     */
  /* ══════════════════════════════════════════════════════════════════ */
  .appendix-section { margin-bottom: 8mm; }

  .appendix-section h3 {
    font-size: 10px;
    font-weight: 700;
    color: var(--grey);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 4mm;
    padding-bottom: 2px;
    border-bottom: 1px solid var(--divider);
  }

  .appendix-row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 4px 0;
    border-bottom: 1px solid var(--divider);
    font-size: 9px;
  }
  .appendix-row:last-child { border-bottom: none; }

  .appendix-row .region-name {
    font-weight: 700;
    width: 40px;
  }

  .appendix-row .row-detail {
    color: var(--grey);
  }

  .meta-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 9px;
  }
  .meta-table td {
    padding: 4px 6px;
    border-bottom: 1px solid var(--divider);
    vertical-align: top;
  }
  .meta-table td:first-child {
    color: var(--grey);
    width: 38%;
    font-weight: 500;
  }
  .meta-table tr:last-child td { border-bottom: none; }
</style>
</head>
<body>

{# ══════════════════════════════════════════════════════════════════ COVER #}
<div class="page">
  <div class="cover-body">

    <div>
      <div class="cover-client">AeroGrid Wind Solutions</div>
      <div class="cover-title">
        <h1>Cyber Risk Intelligence Brief</h1>
      </div>
    </div>

    <div>
      <div class="status-strip">
        <span class="item">
          <span class="chip chip-esc">ESCALATED</span>
          <strong>{{ data.escalated_count }}</strong>
        </span>
        <span class="item">
          <span class="chip chip-mon">MONITOR</span>
          <strong>{{ data.monitor_count }}</strong>
        </span>
        <span class="item">
          <span class="chip chip-clr">CLEAR</span>
          <strong>{{ data.clear_count }}</strong>
        </span>
      </div>
    </div>

    <div class="cover-meta-block">
      <div class="meta-text">Date: {{ data.timestamp }}</div>
      <div class="meta-text">Pipeline ID: {{ data.run_id }}</div>
      <div class="meta-text">Regions Assessed: {{ data.regions | length }}</div>
      <div><span class="cover-classification">CONFIDENTIAL</span></div>
    </div>

  </div>
</div>

{# ══════════════════════════════════════════════════════════════════ GLOBAL POSTURE #}
<div class="page">
  <div class="page-body">

    <div class="page-heading">
      <h2>Global Risk Posture</h2>
      <div style="margin-top:4px;">
        <div class="status-strip">
          <span class="item">
            <span class="chip chip-esc">ESCALATED</span>
            <strong>{{ data.escalated_count }}</strong>
          </span>
          <span class="item">
            <span class="chip chip-mon">MONITOR</span>
            <strong>{{ data.monitor_count }}</strong>
          </span>
          <span class="item">
            <span class="chip chip-clr">CLEAR</span>
            <strong>{{ data.clear_count }}</strong>
          </span>
        </div>
      </div>
    </div>

    <div class="exec-summary">{{ data.exec_summary }}</div>

    {% set escalated_regions = data.regions | selectattr("status", "equalto", "escalated") | list %}
    {% if escalated_regions %}
    <hr class="divider">
    <table class="region-table">
      <thead>
        <tr>
          <th>Region</th>
          <th>Scenario</th>
          <th>Confidence</th>
          <th>Velocity</th>
          <th>Severity</th>
        </tr>
      </thead>
      <tbody>
        {% for r in escalated_regions %}
        <tr>
          <td><strong>{{ r.name }}</strong></td>
          <td>{{ r.scenario_match or "—" }}</td>
          <td>{{ r.confidence_label or "Unknown" }}</td>
          <td>
            {% if r.velocity == "accelerating" %}
              <span class="vel-up">↑ Accelerating</span>
            {% elif r.velocity == "improving" %}
              <span class="vel-down">↓ Improving</span>
            {% elif r.velocity == "stable" %}
              <span class="vel-flat">→ Stable</span>
            {% else %}
              <span class="vel-none">— Unknown</span>
            {% endif %}
          </td>
          <td>
            {% if r.severity %}
              {% set sev_lower = r.severity | lower %}
              <span class="chip chip-sev-{{ sev_lower }}">{{ r.severity | upper }}</span>
            {% else %}—{% endif %}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% endif %}

  </div>
</div>

{# ══════════════════════════════════════════════════════════════════ REGION PAGES #}
{% for r in data.regions if r.status == "escalated" %}
<div class="page">
  <div class="page-body">

    <div class="region-header">
      <div class="region-header-left">
        <h2>{{ r.name }}</h2>
        <div class="region-sub">
          {{ r.scenario_match or "" }}
          {% if r.signal_type %} · {{ r.signal_type }}{% endif %}
          {% if r.confidence_label %} · Confidence: {{ r.confidence_label }}{% endif %}
        </div>
      </div>
      <div>
        {% if r.severity %}
          {% set sev_lower = r.severity | lower %}
          <span class="chip chip-sev-{{ sev_lower }}">{{ r.severity | upper }}</span>
        {% endif %}
      </div>
    </div>

    <hr class="divider">

    {# ── Region meta row ──────────────────────────────────────────────── #}
    <div class="region-meta">
      {% if r.threat_actor %}
        <span class="meta-item"><strong>Threat Actor:</strong> {{ r.threat_actor }}</span>
      {% endif %}
      {% if r.signal_type_label %}
        <span class="meta-item"><strong>Signal Type:</strong> {{ r.signal_type_label }}</span>
      {% endif %}
    </div>

    {# ── Intelligence sections ─────────────────────────────────────────── #}
    {% if r.intel_bullets %}
    <div class="intel-section">
      <div class="section-heading">Intel Findings</div>
      <ul class="intel-list">
        {% for b in r.intel_bullets %}<li>{{ b }}</li>{% endfor %}
      </ul>
    </div>
    {% endif %}

    {% if r.adversary_bullets %}
    <div class="intel-section">
      <div class="section-heading">Observed Adversary Activity</div>
      <ul class="intel-list">
        {% for b in r.adversary_bullets %}<li>{{ b }}</li>{% endfor %}
      </ul>
    </div>
    {% endif %}

    {% if r.impact_bullets %}
    <div class="intel-section impact">
      <div class="section-heading">Impact for AeroGrid</div>
      <ul class="intel-list">
        {% for b in r.impact_bullets %}<li>{{ b }}</li>{% endfor %}
      </ul>
    </div>
    {% endif %}

    {% if r.watch_bullets %}
    <div class="intel-section watch">
      <div class="section-heading">Watch For — Adversary Tradecraft</div>
      <ul class="intel-list">
        {% for b in r.watch_bullets %}<li>{{ b }}</li>{% endfor %}
      </ul>
    </div>
    {% endif %}

    {% if r.action_bullets %}
    <div class="intel-section actions">
      <div class="section-heading">Recommended Actions</div>
      <ul class="intel-list">
        {% for b in r.action_bullets %}<li>{{ b }}</li>{% endfor %}
      </ul>
    </div>
    {% endif %}

    {% if not r.intel_bullets and not r.adversary_bullets %}
      <div class="unavailable-notice">
        Detailed intelligence analysis is unavailable for this region this cycle.
      </div>
    {% endif %}

  </div>

  <div class="region-footer">
    <span>
      Trend:&nbsp;
      {% if r.velocity == "accelerating" %}<span class="vel-up">↑ Accelerating</span>
      {% elif r.velocity == "improving"  %}<span class="vel-down">↓ Improving</span>
      {% elif r.velocity == "stable"     %}<span class="vel-flat">→ Stable</span>
      {% else %}<span class="vel-none">— Unknown</span>{% endif %}
    </span>
    {% if r.threat_characterisation %}
      <span>·&nbsp;{{ r.threat_characterisation }}</span>
    {% endif %}
    {% if r.source_quality and r.source_quality.total > 0 %}
      <span style="margin-left:auto;">
        Sources: {{ r.source_quality.tier_a }}A · {{ r.source_quality.tier_b }}B · {{ r.source_quality.tier_c }}C
      </span>
    {% elif r.top_sources %}
      <span style="margin-left:auto;font-style:italic;">Sources: {{ r.top_sources | join(" · ") }}</span>
    {% endif %}
  </div>
</div>
{% endfor %}

{# ══════════════════════════════════════════════════════════════════ APPENDIX #}
<div class="page">
  <div class="page-body">

    <div class="page-heading">
      <h2>Appendix</h2>
    </div>

    {% set monitor_regions = data.regions | selectattr("status", "equalto", "monitor") | list %}
    {% if monitor_regions %}
    <div class="appendix-section">
      <h3>Monitor Regions</h3>
      {% for r in monitor_regions %}
      <div class="appendix-row">
        <span class="chip chip-mon">MONITOR</span>
        <span class="region-name">{{ r.name }}</span>
        <span class="row-detail">
          {{ r.scenario_match or "No scenario matched" }}
          {% if r.severity %} · {{ r.severity }}{% endif %}
        </span>
      </div>
      {% endfor %}
    </div>
    {% endif %}

    {% set clear_regions = data.regions | selectattr("status", "equalto", "clear") | list %}
    {% if clear_regions %}
    <div class="appendix-section">
      <h3>Clear Regions</h3>
      {% for r in clear_regions %}
      <div class="appendix-row">
        <span class="chip chip-clr">CLEAR</span>
        <span class="region-name">{{ r.name }}</span>
        <span class="row-detail">No active threat this cycle.</span>
      </div>
      {% endfor %}
    </div>
    {% endif %}

    <div class="appendix-section">
      <h3>Run Metadata</h3>
      <table class="meta-table">
        <tr><td>Pipeline ID</td><td>{{ data.run_id }}</td></tr>
        <tr><td>Timestamp</td><td>{{ data.timestamp }}</td></tr>
        <tr><td>Escalated</td><td>{{ data.escalated_count }}</td></tr>
        <tr><td>Monitor</td><td>{{ data.monitor_count }}</td></tr>
        <tr><td>Clear</td><td>{{ data.clear_count }}</td></tr>
      </table>
    </div>

  </div>
</div>

</body>
</html>
