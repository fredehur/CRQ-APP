# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Pipeline output (generated state, not source)
output/runs/
output/latest/

# OSINT signal files (generated by collectors — not source-controlled)
output/regional/*/geo_signals.json
output/regional/*/cyber_signals.json
output/regional/*/scenario_map.json
output/regional/*/gatekeeper_decision.json

# Hook runtime state (circuit breaker attempt counts)
.claude/hooks/.attempts/

# Git worktrees
.worktrees/
